{
  "annotations": {
    "list": []
  },
  "description": "Public-marketplace submission, review, fork, and rate-limit telemetry for UPD-049.",
  "editable": true,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "$prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Public submissions per minute (by category)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (category) (rate(marketplace_submissions_total[1m]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Review decisions (approve / reject)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (decision) (rate(marketplace_review_decisions_total[5m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Fork operations (by target scope)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (target_scope) (rate(marketplace_forks_total[5m]))",
          "legendFormat": "{{target_scope}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Rate-limit refusals (FR-009)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(marketplace_rate_limit_refusals_total[5m])",
          "legendFormat": "refusals/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "title": "Review age — submission to decision (p50/p90/p99)",
      "description": "How long submissions wait before approve/reject. Operational SLA per UPD-049 SC-001 is observable median wall time submission → approve.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, decision) (rate(marketplace_review_age_seconds_bucket[1h])))",
          "legendFormat": "p50 {{decision}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le, decision) (rate(marketplace_review_age_seconds_bucket[1h])))",
          "legendFormat": "p90 {{decision}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, decision) (rate(marketplace_review_age_seconds_bucket[1h])))",
          "legendFormat": "p99 {{decision}}",
          "refId": "C"
        }
      ]
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 6,
      "title": "Review queue listing latency (p95) — SC-007",
      "description": "Time from /admin/marketplace-review/queue request to response, p95. UPD-049 SC-007 target: <2s p95.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{handler=~\".*admin/marketplace-review/queue.*\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 7,
      "title": "Rejection notification delivery (p95) — SC-008",
      "description": "Time from reviewer recording a rejection to the submitter receiving the notification, p95. UPD-049 SC-008 target: <60s p95. Source: log-derived metric over `marketplace.review.rejected` and `notifications.review_rejected.delivered` events.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(marketplace_review_rejection_notification_latency_seconds_bucket[15m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 8,
      "title": "Reviewer assignments per minute (UPD-049 refresh — assigned/unassigned)",
      "description": "Rate of assign + unassign actions on the review queue. Helps platform-staff leads see queue-load distribution.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (event_type) (rate(marketplace_events_total{event_type=~\"marketplace\\\\.review\\\\.(assigned|unassigned)\"}[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 9,
      "title": "Self-review attempts (UPD-049 refresh FR-741.9)",
      "description": "Refused self-review attempts per minute. Sustained non-zero is a signal for misconfigured frontends or replay attempts.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (action) (rate(marketplace_self_review_attempts_total[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["marketplace", "upd-049"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
