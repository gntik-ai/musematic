{
  "apiVersion": 1,
  "providers": [
    {
      "name": "trust-content-moderation",
      "orgId": 1,
      "folder": "Trust",
      "type": "file",
      "disableDeletion": false,
      "editable": true,
      "options": {
        "path": "/var/lib/grafana/dashboards/trust-content-moderation"
      }
    }
  ],
  "dashboard": {
    "title": "Trust Content Moderation",
    "tags": ["trust", "content-moderation", "fairness"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "Moderation Trigger Rate by Category",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum by (workspace_id, category) (rate(content_moderation_triggered_total[5m]))",
            "legendFormat": "\u007b\u007bworkspace_id\u007d\u007d \u007b\u007bcategory\u007d\u007d"
          }
        ]
      },
      {
        "id": 2,
        "title": "Action Breakdown",
        "type": "barchart",
        "targets": [
          {
            "expr": "sum by (workspace_id, action) (increase(content_moderation_actions_total[1h]))",
            "legendFormat": "\u007b\u007bworkspace_id\u007d\u007d \u007b\u007baction\u007d\u007d"
          }
        ]
      },
      {
        "id": 3,
        "title": "Provider Failure Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum by (workspace_id, provider) (rate(content_moderation_provider_failed_total[5m]))",
            "legendFormat": "\u007b\u007bworkspace_id\u007d\u007d \u007b\u007bprovider\u007d\u007d"
          }
        ]
      },
      {
        "id": 4,
        "title": "Fairness Evaluations",
        "type": "stat",
        "targets": [
          {
            "expr": "sum by (workspace_id) (increase(fairness_evaluations_total[24h]))",
            "legendFormat": "\u007b\u007bworkspace_id\u007d\u007d"
          }
        ]
      }
    ]
  }
}
