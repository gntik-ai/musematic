cluster_name              = "musematic-prod"
control_plane_count       = 1
worker_count              = 3
control_plane_server_type = "ccx33"
worker_server_type        = "ccx53"
location                  = "fsn1"
network_zone              = "eu-central"
firewall_allowed_cidrs    = ["203.0.113.10/32"]
load_balancer_type        = "lb11"
ssh_public_key_file       = "~/.ssh/id_ed25519.pub"
